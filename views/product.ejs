<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chi tiết sản phẩm — Our Blossoms</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet" />
  <style>
    /* ... (CSS gốc của bạn được giữ nguyên) ... */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cream: #faf7f2;
      --warm-white: #f5f0e8;
      --sage: #8a9e7a;
      --sage-light: #b5c9a1;
      --moss: #4a5e3a;
      --blush: #e8b4b8;
      --terracotta: #c07860;
      --charcoal: #2a2a28;
      --ink: #1a1a18;
      --muted: #8a8680;
      --border: #ddd8d0;
      --red: #d0453a;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--cream);
      color: var(--charcoal);
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 3rem; height: 64px;
      background: rgba(250,247,242,0.96);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem; font-weight: 400;
      letter-spacing: 0.08em; color: var(--ink); text-decoration: none;
    }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--muted); text-decoration: none; transition: color 0.25s;
    }
    .nav-links a:hover { color: var(--moss); }

    /* ── BREADCRUMB ── */
    .breadcrumb {
      max-width: 1200px; margin: 1.5rem auto; padding: 0 2rem;
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.72rem; color: var(--muted);
    }
    .breadcrumb a { color: var(--muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--moss); }
    .breadcrumb span { color: var(--charcoal); }
    .bc-sep { opacity: 0.4; }

    /* ── MAIN LAYOUT ── */
    .product-page {
      max-width: 1200px; margin: 0 auto 4rem;
      padding: 0 2rem;
      display: grid;
      grid-template-columns: 520px 1fr;
      gap: 3rem;
      align-items: start;
    }

    /* ── LEFT: IMAGE COLUMN ── */
    .image-col { position: sticky; top: 80px; }

    .main-image-wrap {
      width: 100%; aspect-ratio: 1/1;
      background: var(--warm-white);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 9rem;
      overflow: hidden; position: relative;
      cursor: zoom-in;
    }
    #mainPhoto{
     width:100%; height:100%; object-fit:cover; display:block;
    }
    .main-image-wrap:hover .zoom-hint { opacity: 1; }
    .zoom-hint {
      position: absolute; bottom: 1rem; right: 1rem;
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--muted); opacity: 0; transition: opacity 0.3s;
      background: rgba(250,247,242,0.85); padding: 0.35rem 0.7rem;
      border: 1px solid var(--border);
    }

    .thumbnails {
      display: flex; gap: 0.75rem; margin-top: 1rem;
      overflow-x: auto; padding-bottom: 0.25rem;
    }
    .thumb {
      flex: 0 0 80px; height: 80px;
      border: 1.5px solid var(--border); background: var(--warm-white);
      display: flex; align-items: center; justify-content: center;
      font-size: 2rem; cursor: pointer; transition: border-color 0.2s;
    }
    .thumb img{
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .thumb:hover, .thumb.active { border-color: var(--moss); }

    .share-row {
      margin-top: 1.5rem; display: flex; align-items: center; gap: 1rem;
      padding-top: 1.5rem; border-top: 1px solid var(--border);
    }
    .share-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }
    .share-icons { display: flex; gap: 0.5rem; }
    .share-icon {
      width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem; cursor: pointer; transition: background 0.2s;
      color: var(--muted); text-decoration: none;
    }
    .share-icon:hover { background: var(--warm-white); color: var(--charcoal); }

    .like-btn {
      margin-left: auto; display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.72rem; color: var(--muted); cursor: pointer;
      background: none; border: 1px solid var(--border);
      padding: 0.4rem 0.9rem; transition: all 0.2s;
    }
    .like-btn:hover { border-color: var(--blush); color: var(--terracotta); }
    .like-btn.liked { border-color: var(--blush); color: var(--terracotta); background: #fdf5f5; }

    /* ── RIGHT: INFO COLUMN ── */
    .product-badge {
      display: inline-block; background: var(--red); color: #fff;
      font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
      padding: 0.25rem 0.6rem; margin-bottom: 0.8rem;
    }
    .product-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.85rem; font-weight: 300; line-height: 1.25;
      color: var(--ink); margin-bottom: 0.4rem;
    }
    .product-latin {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.9rem; color: var(--muted);
      margin-bottom: 1rem;
    }

    /* Rating row */
    .rating-row {
      display: flex; align-items: center; gap: 1.5rem;
      padding-bottom: 1rem; border-bottom: 1px solid var(--border);
      margin-bottom: 1.25rem; font-size: 0.78rem;
    }
    .stars { color: #f5a623; font-size: 0.9rem; }
    .rating-num { font-weight: 500; color: var(--terracotta); }
    .review-count { color: var(--muted); }
    .sold-count { color: var(--muted); padding-left: 1.5rem; border-left: 1px solid var(--border); }

    /* Price box */
    .price-box {
      background: var(--warm-white); padding: 1.25rem 1.5rem;
      margin-bottom: 1.5rem; border-left: 3px solid var(--terracotta);
    }
    .price-main {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem; color: var(--terracotta); font-weight: 400; line-height: 1;
    }
    .price-original {
      font-size: 0.85rem; color: var(--muted); text-decoration: line-through; margin-left: 0.75rem;
    }
    .price-discount {
      font-size: 0.7rem; font-weight: 500; background: var(--terracotta); color: #fff;
      padding: 0.2rem 0.5rem; margin-left: 0.5rem;
    }
    .price-row { display: flex; align-items: baseline; flex-wrap: wrap; gap: 0.25rem; }

    /* Info rows */
    .info-row {
      display: grid; grid-template-columns: 140px 1fr; gap: 0.5rem 1rem; align-items: start;
      padding: 1rem 0; border-bottom: 1px solid var(--border); font-size: 0.8rem;
    }
    .info-row:last-of-type { border-bottom: none; }
    .row-label { color: var(--muted); font-size: 0.72rem; padding-top: 0.1rem; }
    .row-value { color: var(--charcoal); }

    .voucher-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .voucher-chip {
      border: 1px solid var(--terracotta); color: var(--terracotta);
      font-size: 0.65rem; padding: 0.25rem 0.65rem; cursor: pointer; transition: background 0.2s;
    }
    .voucher-chip:hover { background: #fff5f3; }
    .voucher-more { color: var(--sage); font-size: 0.65rem; display: flex; align-items: center; gap: 0.3rem; cursor: pointer; }

    .combo-tag {
      background: #fff5f3; border: 1px solid var(--blush); color: var(--terracotta);
      font-size: 0.7rem; padding: 0.3rem 0.75rem; display: inline-block;
    }

    .ship-info { display: flex; flex-direction: column; gap: 0.3rem; }
    .ship-line { display: flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; }
    .ship-line .ship-icon { color: var(--sage); }
    .ship-free { font-weight: 500; color: var(--charcoal); }
    .ship-voucher { font-size: 0.7rem; color: var(--muted); }

    .trust-badge { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; color: var(--charcoal); }
    .trust-icon { color: var(--moss); font-size: 1rem; }
    .trust-link { color: var(--moss); cursor: pointer; }

    .color-opts { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .color-opt {
      display: flex; align-items: center; gap: 0.5rem; border: 1.5px solid var(--border);
      padding: 0.35rem 0.9rem; cursor: pointer; font-size: 0.75rem; transition: border-color 0.2s;
    }
    .color-opt:hover { border-color: var(--moss); }
    .color-opt.active { border-color: var(--moss); background: #f5f8f4; }
    .color-dot { width: 14px; height: 14px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.15); }

    .qty-ctrl { display: flex; align-items: center; gap: 0; }
    .qty-btn {
      width: 36px; height: 36px; border: 1px solid var(--border); background: var(--warm-white);
      cursor: pointer; font-size: 1.1rem; color: var(--charcoal);
      display: flex; align-items: center; justify-content: center; transition: background 0.2s;
    }
    .qty-btn:hover { background: var(--border); }
    .qty-input {
      width: 52px; height: 36px; border: 1px solid var(--border); border-left: none; border-right: none;
      text-align: center; font-family: 'Jost', sans-serif; font-size: 0.85rem; background: #fff; color: var(--charcoal); outline: none;
    }
    .qty-stock { font-size: 0.7rem; color: var(--muted); margin-left: 1rem; align-self: center; }

    .cta-row { display: flex; gap: 1rem; margin-top: 2rem; }
    .btn-cart {
      flex: 1; padding: 1rem 1.5rem; border: 1.5px solid var(--moss); background: transparent; color: var(--moss);
      font-family: 'Jost', sans-serif; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
      cursor: pointer; transition: all 0.25s; display: flex; align-items: center; justify-content: center; gap: 0.6rem;
    }
    .btn-cart:hover { background: var(--moss); color: #fff; }
    .btn-buy {
      flex: 1; padding: 1rem 1.5rem; border: none; background: var(--terracotta); color: #fff;
      font-family: 'Jost', sans-serif; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
      cursor: pointer; transition: background 0.25s;
    }
    .btn-buy:hover { background: #a8634e; }

    /* ── TABS ── */
    .tabs-section { max-width: 1200px; margin: 3rem auto 0; padding: 0 2rem 4rem; }
    .tabs-nav { display: flex; border-bottom: 2px solid var(--border); margin-bottom: 2rem; gap: 0; }
    .tab-btn {
      padding: 0.75rem 2rem; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--muted); cursor: pointer; background: none; border: none; border-bottom: 2px solid transparent; margin-bottom: -2px;
      transition: all 0.2s; font-family: 'Jost', sans-serif;
    }
    .tab-btn:hover { color: var(--charcoal); }
    .tab-btn.active { color: var(--moss); border-bottom-color: var(--moss); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .desc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
    .desc-emoji-block {
      aspect-ratio: 1; background: var(--warm-white); display: flex; align-items: center; justify-content: center;
      font-size: 8rem; border: 1px solid var(--border);
    }
    .desc-heading { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; margin-bottom: 1rem; color: var(--ink); }
    .desc-body { font-size: 0.82rem; line-height: 2; color: #555550; margin-bottom: 1.5rem; }
    .spec-table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
    .spec-table tr { border-bottom: 1px solid var(--border); }
    .spec-table td { padding: 0.7rem 1rem; font-size: 0.78rem; }
    .spec-table td:first-child { color: var(--muted); width: 42%; }
    .spec-table td:last-child { color: var(--charcoal); font-weight: 400; }
    .spec-table tr:nth-child(even) td { background: var(--warm-white); }

    .care-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .care-card { padding: 1.5rem; border: 1px solid var(--border); background: var(--warm-white); }
    .care-icon { font-size: 1.8rem; margin-bottom: 0.75rem; }
    .care-title { font-family: 'Cormorant Garamond', serif; font-size: 1rem; margin-bottom: 0.5rem; color: var(--ink); }
    .care-text { font-size: 0.75rem; line-height: 1.8; color: var(--muted); }

    .review-summary {
      display: flex; gap: 3rem; align-items: center; padding: 2rem; background: var(--warm-white);
      border: 1px solid var(--border); margin-bottom: 2rem;
    }
    .review-big-num { font-family: 'Cormorant Garamond', serif; font-size: 4rem; color: var(--terracotta); line-height: 1; }
    .review-stars-big { font-size: 1.4rem; color: #f5a623; margin: 0.3rem 0; }
    .review-total { font-size: 0.72rem; color: var(--muted); }
    .review-bars { flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
    .bar-row { display: flex; align-items: center; gap: 0.75rem; font-size: 0.72rem; color: var(--muted); }
    .bar-track { flex: 1; height: 6px; background: var(--border); }
    .bar-fill { height: 100%; background: var(--sage); }

    .review-list { display: flex; flex-direction: column; gap: 1.5rem; }
    .review-item { padding: 1.5rem; border: 1px solid var(--border); background: #fff; }
    .review-top { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
    .review-avatar {
      width: 36px; height: 36px; border-radius: 50%; background: var(--sage-light);
      display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: var(--moss); font-weight: 500;
    }
    .review-meta { flex: 1; }
    .review-author { font-size: 0.8rem; font-weight: 500; color: var(--charcoal); }
    .review-date { font-size: 0.65rem; color: var(--muted); }
    .review-stars { color: #f5a623; font-size: 0.8rem; }
    .review-text { font-size: 0.8rem; line-height: 1.8; color: #555550; }
    .review-variant { font-size: 0.65rem; color: var(--muted); margin-top: 0.5rem; }

    /* ── RELATED ── */
    .related-section { max-width: 1200px; margin: 0 auto; padding: 0 2rem 4rem; }
    .related-header {
      font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 300;
      margin-bottom: 1.5rem; color: var(--ink); display: flex; align-items: center; gap: 1rem;
    }
    .related-header::before { content: ''; display: block; width: 32px; height: 1px; background: var(--sage); }
    .related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
    .related-card {
      border: 1px solid var(--border); background: var(--warm-white); cursor: pointer;
      transition: transform 0.3s, box-shadow 0.3s; text-decoration: none; color: inherit; display: block;
    }
    .related-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }
    .related-thumb{ aspect-ratio:1; overflow:hidden; }
    .related-thumb img{ width:100%; height:100%; object-fit:cover; display:block; }
    .related-info { padding: 1rem; border-top: 1px solid var(--border); }
    .related-name { font-family: 'Cormorant Garamond', serif; font-size: 1rem; margin-bottom: 0.25rem; color: var(--ink); }
    .related-price { font-size: 0.75rem; color: var(--terracotta); }

    /* ── FOOTER ── */
    footer {
      background: var(--ink); padding: 3rem; display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 1.5rem;
    }
    .footer-brand { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 300; color: #fff; }
    .footer-copy { font-size: 0.62rem; color: rgba(255,255,255,0.25); }

    /* Responsive */
    @media (max-width: 960px) {
      .product-page { grid-template-columns: 1fr; }
      .image-col { position: static; }
      .desc-grid { grid-template-columns: 1fr; }
      .care-grid { grid-template-columns: 1fr 1fr; }
      .related-grid { grid-template-columns: repeat(2, 1fr); }
      nav { padding: 0 1.5rem; }
    }
    @media (max-width: 560px) {
      .cta-row { flex-direction: column; }
      .care-grid { grid-template-columns: 1fr; }
      .related-grid { grid-template-columns: 1fr 1fr; }
    }

    .page-enter { opacity: 0; transform: translateY(16px); animation: pageIn 0.5s ease forwards; }
    @keyframes pageIn { to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>

<nav>
  <a class="nav-logo" href="/">Flower Premium</a>
  <ul class="nav-links">
    <li><a href="/gallery">Gallery</a></li>
    <li><a href="/gallery#services">About</a></li>
    <li><a href="/gallery#contact">Contact</a></li>
  </ul>
</nav>

<nav class="breadcrumb" id="breadcrumb">
  <a href="/">Flower Premium</a>
  <span class="bc-sep">›</span>
  <a href="/gallery">Gallery</a>
  <span class="bc-sep">›</span>
  <span id="bcName">Đang tải...</span>
</nav>

<div class="product-page page-enter" id="productPage">

  <div class="image-col">
    <div class="main-image-wrap" id="mainImg">
      <img id="mainPhoto" src="" alt="Ảnh hoa">
      <div class="zoom-hint">Xem chi tiết</div>
    </div>
    <div class="thumbnails" id="thumbs"></div>
    <div class="share-row">
      <span class="share-label">Chia sẻ:</span>
      <div class="share-icons">
        <a class="share-icon" href="#" title="Facebook">f</a>
        <a class="share-icon" href="#" title="Messenger">m</a>
        <a class="share-icon" href="#" title="Pinterest">p</a>
        <a class="share-icon" href="#" title="Twitter / X">𝕏</a>
      </div>
      <button class="like-btn" id="likeBtn" onclick="toggleLike()">
        <span id="likeHeart">♡</span>
        <span id="likeCount">468</span> Đã thích
      </button>
    </div>
  </div>

  <div class="info-col">
    <div class="product-badge" id="badge">Yêu thích</div>
    <h1 class="product-name" id="prodName"></h1>
    <p class="product-latin" id="prodLatin"></p>

    <div class="rating-row">
      <span class="rating-num" id="ratingNum">4.8</span>
      <span class="stars" id="stars">★★★★★</span>
      <span class="review-count" id="reviewCount">23,6k Đánh Giá</span>
      <span class="sold-count" id="soldCount"></span>
    </div>

    <div class="price-box">
      <div class="price-row">
        <span class="price-main" id="priceMain"></span>
        <span class="price-original" id="priceOrig"></span>
        <span class="price-discount" id="priceDisc"></span>
      </div>
    </div>

    <div class="info-row">
      <div class="row-label">Mã Giảm Giá</div>
      <div class="row-value">
        <div class="voucher-chips">
          <div class="voucher-chip">Giảm 3%</div>
          <div class="voucher-chip">Giảm 5%</div>
          <div class="voucher-chip">Giảm 8%</div>
          <div class="voucher-more">Xem tất cả ›</div>
        </div>
      </div>
    </div>

    <div class="info-row">
      <div class="row-label">Combo Khuyến Mãi</div>
      <div class="row-value"><span class="combo-tag">Mua 2 & giảm 5%</span></div>
    </div>

    <div class="info-row">
      <div class="row-label">Vận Chuyển</div>
      <div class="row-value">
        <div class="ship-info">
          <div class="ship-line">
            <span class="ship-icon">🚚</span>
            <span>Nhận trong <strong>9 Th06</strong> &nbsp;›</span>
          </div>
          <div class="ship-line">
            <span class="ship-free">Phí ship 0đ</span>
          </div>
          <div class="ship-voucher">Tặng Voucher 15,000đ nếu đơn giao sau thời gian trên.</div>
        </div>
      </div>
    </div>

    <div class="info-row">
      <div class="row-label">An Tâm Mua Sắm</div>
      <div class="row-value">
        <div class="trust-badge">
          <span class="trust-icon">🛡</span>
          <span>Our Blossoms Xử Lý · <span class="trust-link">Trả hàng miễn phí 15 ngày ›</span></span>
        </div>
      </div>
    </div>

    <div class="info-row">
      <div class="row-label">Màu Sắc</div>
      <div class="row-value">
        <div class="color-opts" id="colorOpts"></div>
      </div>
    </div>

    <div class="info-row">
      <div class="row-label">Số Lượng</div>
      <div class="row-value" style="display:flex;align-items:center;">
        <div class="qty-ctrl">
          <button class="qty-btn" onclick="changeQty(-1)">−</button>
          <input class="qty-input" type="number" value="1" min="1" id="qtyInput" />
          <button class="qty-btn" onclick="changeQty(1)">+</button>
        </div>
        <span class="qty-stock" id="qtyStock">Còn 248 sản phẩm</span>
      </div>
    </div>

    <div class="cta-row">
      <button class="btn-cart" onclick="addCart()">🛒 Thêm Vào Giỏ Hàng</button>
      <button class="btn-buy" onclick="buyNow()">Mua Ngay</button>
    </div>
  </div>
</div>

