  const thumbsEl = document.getElementById('thumbs');
  document.getElementById('mainPhoto').src = f.images[0];

  f.images.forEach((img, i) => {
    const d = document.createElement('div');
    d.className = 'thumb' + (i === 0 ? ' active' : '');
    d.innerHTML = `<img src="${img}" style="width:100%;height:100%;object-fit:cover;">`;
    d.onclick = () => {
     document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
     d.classList.add('active');
     document.getElementById('mainPhoto').src = img;
   };
    thumbsEl.appendChild(d);
  });

  document.getElementById('badge').textContent = f.tag;
  document.getElementById('prodName').textContent = f.name;
  document.getElementById('prodLatin').textContent = f.latin;
  document.getElementById('soldCount').textContent = f.sold;
  document.getElementById('qtyStock').textContent = `Còn ${f.stock} sản phẩm`;

  document.getElementById('priceMain').textContent = f.price;
  if(f.origPrice) document.getElementById('priceOrig').textContent = f.origPrice;
  if(f.disc) document.getElementById('priceDisc').textContent = f.disc;

  const colorEl = document.getElementById('colorOpts');
  f.colors.forEach((c, i) => {
    const btn = document.createElement('div');
    btn.className = 'color-opt' + (i === 0 ? ' active' : '');
    btn.innerHTML = `<span class="color-dot" style="background:${c.dot}"></span>${c.name}`;
    btn.onclick = () => {
      document.querySelectorAll('.color-opt').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    };
    colorEl.appendChild(btn);
  });

  document.getElementById('descTitle').textContent = f.name;
  document.getElementById('descBody').textContent = f.desc;
  const tagsEl = document.getElementById('descTags');
  f.tags.forEach(t => {
    const span = document.createElement('span');
    span.style.cssText = 'font-size:0.65rem;letter-spacing:0.1em;padding:0.3rem 0.8rem;border:1px solid var(--border);color:var(--muted)';
    span.textContent = t;
    tagsEl.appendChild(span);
  });

  const specTable = document.getElementById('specTable');
  f.specs.forEach(([label, val]) => {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td>${label}</td><td>${val}</td>`;
    specTable.appendChild(tr);
  });

  const reviewList = document.getElementById('reviewList');
  if(f.reviews) {
      f.reviews.forEach(r => {
        const stars = '★'.repeat(r.stars) + '☆'.repeat(5-r.stars);
        const div = document.createElement('div');
        div.className = 'review-item';
        div.innerHTML = `
          <div class="review-top">
            <div class="review-avatar">${r.name[0]}</div>
            <div class="review-meta">
              <div class="review-author">${r.name}</div>
              <div class="review-date">${r.date}</div>
            </div>
            <div class="review-stars">${stars}</div>
          </div>
          <div class="review-text">${r.text}</div>
          <div class="review-variant">Phân loại: ${r.variant}</div>
        `;
        reviewList.appendChild(div);
      });
  }

  const relatedGrid = document.getElementById('relatedGrid');
  flowers.filter((_, i) => i !== id).slice(0, 4).forEach((rel, ri) => {
    const relId = flowers.indexOf(rel);
    const a = document.createElement('a');
    a.className = 'related-card';
    
    // ĐÃ SỬA: Đường dẫn nhấp vào sản phẩm liên quan cũng phải chuẩn Express
    a.href = `/product?id=${relId}`;
    
    const thumbImage = rel.images ? rel.images[0] : rel.imgUrl;
    a.innerHTML = `
      <div class="related-thumb"><img src="${thumbImage}" alt="${rel.name}"></div>
      <div class="related-info">
          <div class="related-name">${rel.name}</div>
          <div class="related-price">${rel.price}</div>
      </div>
    `;
    relatedGrid.appendChild(a);
  });
}

function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
}

let liked = false, count = 468;
function toggleLike() {
  liked = !liked; count += liked ? 1 : -1;
  document.getElementById('likeHeart').textContent = liked ? '♥' : '♡';
  document.getElementById('likeCount').textContent = count;
  document.getElementById('likeBtn').classList.toggle('liked', liked);
}

function changeQty(delta) {
  const inp = document.getElementById('qtyInput');
  inp.value = Math.max(1, parseInt(inp.value) + delta);
}

function addCart() {
  const btn = document.querySelector('.btn-cart');
  btn.textContent = '✓ Đã thêm vào giỏ!';
  btn.style.background = 'var(--moss)'; btn.style.color = '#fff';
  setTimeout(() => { btn.innerHTML = '🛒 Thêm Vào Giỏ Hàng'; btn.style.background=''; btn.style.color=''; }, 2000);
}
function buyNow() { alert('Chức năng thanh toán đang được phát triển!'); }
</script>
</body>
</html>