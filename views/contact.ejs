<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Liên Hệ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

   <style>
body{
    background:#F8F7F3;
    color:#2F5D50;
}

.navbar{
    background:#F8F7F3 !important;
    border-bottom:1px solid #dcdcdc;
}

.navbar-brand{
    font-weight:bold;
    color:#2F5D50 !important;
    font-size:28px;
}

.nav-link-custom{
    color:#2F5D50;
    text-decoration:none;
    margin-left:20px;
    font-weight:500;
}

.nav-link-custom:hover{
    color:#5F8D76;
}

.contact-card{
    max-width:700px;
    margin:60px auto;
    border:none;
    border-radius:20px;
    box-shadow:0 5px 15px rgba(0,0,0,0.08);
}

.form-control{
    border-radius:10px;
}

.btn-contact{
    background:#2F5D50;
    color:white;
    border:none;
}

.btn-contact:hover{
    background:#5F8D76;
    color:white;
}

#status{
    font-weight:bold;
}
</style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg shadow-sm">>
        <div class="container">
            <a class="navbar-brand" href="/">Flower Premiu</a>

            <div>
               <div>
                <a href="/" class="nav-link-custom">Home</a>
                <a href="/about" class="nav-link-custom">About</a>
                <a href="/contact" class="nav-link-custom">Contact</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Form liên hệ -->
    <div class="container">

        <div class="card contact-card shadow-lg">

            <div class="card-body p-5">

                <h1 class="text-center mb-3 fw-bold">
                FlowerPremiu
             </h1>

                <p class="text-center text-muted mb-4">
                Hãy gửi cho chúng tôi những câu hỏi hoặc góp ý của bạn
                </p>

               

                <form id="contactForm">

                    <div class="mb-3">
                        <label class="form-label">
                            Họ và tên
                        </label>

                        <input
                            type="text"
                            id="name"
                            class="form-control"
                            placeholder="Nhập họ tên"
                            required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Email
                        </label>

                        <input
                            type="email"
                            id="email"
                            class="form-control"
                            placeholder="Nhập email"
                            required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">
                            Nội dung
                        </label>

                        <textarea
                            id="message"
                            class="form-control"
                            rows="5"
                            placeholder="Nhập nội dung liên hệ..."
                            required></textarea>
                    </div>

                    <div class="d-grid">
                        <button
                            type="submit"
                             class="btn btn-contact btn-lg">
                            Gửi Liên Hệ
                        </button>
                    </div>

                </form>

                <div id="status" class="mt-4 text-center"></div>

            </div>

        </div>

    </div>

<script>

document.getElementById("contactForm")
.addEventListener("submit", async function(e){

    e.preventDefault();

    const status = document.getElementById("status");

    try{

        const response = await fetch("/send-mail", {

            method: "POST",

            headers:{
                "Content-Type":"application/json"
            },

            body: JSON.stringify({

                name: document.getElementById("name").value,

                email: document.getElementById("email").value,

                message: document.getElementById("message").value

            })
        });

        const data = await response.json();

        if(response.ok){

            status.className =
                "mt-4 text-center text-success";

            status.innerText =
                "✓ Gửi liên hệ thành công!";

            document.getElementById("contactForm").reset();

        }else{

            status.className =
                "mt-4 text-center text-danger";

            status.innerText =
                "✗ Gửi liên hệ thất bại!";
        }

    }catch(error){

        status.className =
            "mt-4 text-center text-danger";

        status.innerText =
            "✗ Không thể kết nối tới máy chủ!";
    }
});

</script>

</body>
</html>