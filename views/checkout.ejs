<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thanh toán - Cây Nhà Lá Cành</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.10.2/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-base-200 min-h-screen p-4 md:p-8">
    
    <div class="max-w-4xl mx-auto bg-base-100 shadow-xl rounded-box p-6 md:p-8">
        <h1 class="text-3xl font-bold mb-8 text-center text-success">Hoàn tất đơn hàng</h1>

        <form id="checkoutForm" class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-4">
                <h2 class="text-xl font-semibold border-b pb-2">Thông tin người nhận</h2>
                
                <div class="form-control">
                    <label class="label"><span class="label-text font-medium">Họ và tên</span></label>
                    <input type="text" id="customer_name" placeholder="Nguyễn Văn A" class="input input-bordered w-full focus:input-success" required />
                </div>
                
                <div class="form-control">
                    <label class="label"><span class="label-text font-medium">Số điện thoại</span></label>
                    <input type="tel" id="customer_phone" placeholder="0901234567" class="input input-bordered w-full focus:input-success" required />
                </div>
                
                <div class="form-control">
                    <label class="label"><span class="label-text font-medium">Địa chỉ nhận hàng</span></label>
                    <textarea id="shipping_address" placeholder="Số nhà, Tên đường, Phường/Xã..." class="textarea textarea-bordered h-24 focus:textarea-success" required></textarea>
                </div>
            </div>

            <div class="space-y-4">
                <h2 class="text-xl font-semibold border-b pb-2">Phương thức thanh toán</h2>
                
                <div class="form-control bg-base-200 rounded-lg p-2">
                    <label class="label cursor-pointer justify-start gap-4">
                        <input type="radio" name="payment_method" value="cod" class="radio radio-success" checked />
                        <span class="label-text text-base font-medium">Thanh toán khi nhận hàng (COD)</span>
                    </label>
                </div>
                
                <div class="form-control bg-base-200 rounded-lg p-2">
                    <label class="label cursor-pointer justify-start gap-4">
                        <input type="radio" name="payment_method" value="payos" class="radio radio-success" />
                        <span class="label-text text-base font-medium">Chuyển khoản mã QR (PayOS)</span>
                    </label>
                </div>

                <div class="divider mt-6"></div>

                <div class="flex justify-between items-center text-xl font-bold">
                    <span>Tổng thanh toán:</span>
                    <span class="text-xl font-bold text-[#16a34a]">
                        <%= (product.price * quantity).toLocaleString('vi-VN') %> đ
                    </span>
                </div>

                <button type="submit" id="submitBtn" class="btn btn-success w-full mt-4 text-white text-lg">
                    Xác nhận đặt hàng
                </button>
            </div>
        </form>
    </div>

    <script>
        document.getElementById('checkoutForm').addEventListener('submit', async function(e) {
            e.preventDefault(); 

            const btn = document.querySelector('button[type="submit"]');
            if (btn) {
                btn.innerHTML = '<span class="loading loading-spinner"></span> Đang xử lý...';
                btn.disabled = true;
            }

            // 1. Lấy dữ liệu thật từ biến EJS mà Backend truyền sang
                    const realProductId = Number('<%= product.id %>');
                    const realQuantity = Number('<%= quantity %>');
                    const realPrice = Number('<%= product.price %>');
                    const totalAmount = realPrice * realQuantity;

                    // 2. Gom dữ liệu người dùng điền + Sản phẩm thật
                    const payload = {
                        customer_name: document.getElementById('customer_name').value,
                        customer_phone: document.getElementById('customer_phone').value,
                        shipping_address: document.getElementById('shipping_address').value,
                        payment_method: document.querySelector('input[name="payment_method"]:checked').value,
                        
                        total: totalAmount, // Truyền tổng tiền thật
                        items: [
                            { 
                                product_id: realProductId,  // Truyền mã hoa thật
                                quantity: realQuantity,     // Truyền số lượng thật
                                price: realPrice            // Truyền giá tiền thật
                            }
                        ]
                    };

            try {
                // 3. Bắn dữ liệu xuống API Backend
                const response = await fetch('/api/orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                // 4. Xử lý kịch bản sau khi Backend trả lời
                if (data.success) {
                    if (payload.payment_method === 'payos' && data.checkoutUrl) {
                        window.location.href = data.checkoutUrl; // Bay sang trang quét QR
                    } else {
                        window.location.href = "/orders/success"; // Bay sang trang báo thành công
                    }
                } else {
                    alert("Từ chối tạo đơn: " + (data.message || data.error));
                    resetButton();
                }
            } catch (error) {
                console.error("Lỗi kết nối:", error);
                alert("Không thể kết nối đến máy chủ. Vui lòng kiểm tra lại mạng!");
                resetButton();
            }

            function resetButton() {
                if (btn) {
                    btn.innerHTML = 'Thanh toán';
                    btn.disabled = false;
                }
            }
        });
    </script>
</body>
</html>