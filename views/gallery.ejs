<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Gallery - Cây nhà lá cành</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/style.css" />
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5/themes.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    
    <style>
      /* Hiệu ứng trượt lên (Reveal) */
      .reveal {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 0.8s ease, transform 0.8s ease;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      /* Ẩn scrollbar ngang nếu có */
      body { overflow-x: hidden; scroll-behavior: smooth; }
    </style>
  </head>

  <body class="font-['Outfit',sans-serif] bg-base-100 text-base-content">
    
    <header>
      <div class="navbar bg-base-100 flex border-b-1 mx-auto w-full max-w-7xl h-auto px-4">
        <div class="flex-1">
          <a href="/">
            <img src="/images/logo.png" alt="Logo" class="logo pb-5 w-auto h-20">
          </a>
        </div>
        
        <div class="flex-none">
          <ul class="menu menu-horizontal px-1 pb-0 gap-8">
            <li><a class="text-sm font-bold" href="/gallery">GALLERY</a></li>
            <li><a class="text-sm font-bold" href="/about">ABOUT</a></li>
            <li>
              <details>
                <summary class="text-sm font-bold">MORE</summary>
                <ul class="bg-base-100 rounded-t-none p-2 w-30 z-50 shadow">
                  <% if (user) { %>
                    <li><b>Hi, <%= user.username %></b></li>
                    <li><a href="/logout">Logout</a></li>
                    <li><a href="/history">Orders</a></li>
                  <% } else { %>
                    <li><a href="/login">Login</a></li>
                  <% } %>
                  <li><a href="/contact">Contact</a></li>
                </ul>
              </details>
            </li>
          </ul>
        </div>
      </div>

      <img src="/images/logo.png" alt="logo" class="mx-auto mb-4 mt-6 w-full max-w-lg h-auto">
    </header>

    <main>
      
      <section class="relative flex flex-col items-center justify-center text-center h-[70vh] bg-[url('/images/romanofiori.webp')] bg-cover bg-center overflow-hidden mx-auto max-w-7xl rounded-4xl mt-6">
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative z-10 text-white reveal">
          <p class="text-sm tracking-[0.35em] uppercase mb-4 opacity-90 font-bold">Floral Studio · Est. 2026</p>
          <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-6">Nơi Những Đoá Hoa<br><span class="italic font-normal">Kể Nên Câu Chuyện</span></h1>
          <p class="text-lg max-w-lg mx-auto opacity-90">Những bó hoa được tạo nên bằng sự tận tâm, nuôi dưỡng bằng sự chăm chút và trao gửi bằng yêu thương.</p>
        </div>
      </section>

      <div id="gallery" class="max-w-7xl mx-auto px-4 py-20">
        
        <div class="border-b-1 pb-8 mb-12 text-center reveal">
          <h2 class="text-6xl font-bold mt-2">OUR GALLERY</h2>
          <p class="text-xl mt-4">Khám phá các tác phẩm nghệ thuật từ hoa.</p>
        </div>

        <div class="flex flex-col lg:flex-row justify-between items-center gap-6 mb-8 reveal">
          <div class="relative w-full lg:w-1/3">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">🔍</span>
            <input type="text" id="searchInput" class="input input-bordered w-full pl-12 rounded-full bg-base-100 shadow-sm" placeholder="Tìm kiếm hoa, cây cảnh...">
          </div>
        
          <div class="flex flex-wrap gap-3 justify-center">
            <select id="categoryFilter" class="select select-bordered rounded-full bg-base-100 shadow-sm font-['Outfit']">
              <option value="all">Tất cả loại</option>
              <option value="romantic">Hoa lãng mạn</option>
              <option value="fresh">Hoa tươi</option>
              <option value="luxury">Hoa cao cấp</option>
              <option value="decorative">Cây trang trí</option>
            </select>
        
            <select id="priceFilter" class="select select-bordered rounded-full bg-base-100 shadow-sm font-['Outfit']">
              <option value="all">Khoảng giá</option>
              <option value="0-200000">Dưới 200.000₫</option>
              <option value="200000-500000">200.000₫ - 500.000₫</option>
              <option value="500000-1000000">500.000₫ - 1.000.000₫</option>
              <option value="1000000-2000000">1.000.000₫ - 2.000.000₫</option>
              <option value="2000000-9999999">Trên 2.000.000₫</option>
            </select>
        
            <select id="sortFilter" class="select select-bordered rounded-full bg-base-100 shadow-sm font-['Outfit']">
              <option value="default">Sắp xếp</option>
              <option value="price-asc">Giá tăng dần</option>
              <option value="price-desc">Giá giảm dần</option>
              <option value="name-asc">Tên A → Z</option>
              <option value="name-desc">Tên Z → A</option>
            </select>
          </div>
        </div>
        
        <div class="text-sm text-gray-500 mb-8 font-medium">
          Hiển thị <span id="productCount" class="font-bold text-[#7a9d66]">21</span> sản phẩm
        </div>
        
        <div class="gallery-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          
          <% products.forEach(function(product) { %>
            <div class="gallery-card group relative overflow-hidden cursor-pointer rounded-3xl aspect-[4/5] shadow-md reveal" 
                data-id="<%= product.id %>" 
                data-category="<%= product.category_slug %>" 
                data-price="<%= product.price %>">
                
              <img src="/images/<%= product.image %>" 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 group-hover:saturate-110" 
                  alt="<%= product.name %>"
                  onerror="this.src='/images/logo.png'">
                  
              <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent p-6 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                <div class="card-name text-white font-bold text-xl"><%= product.name %></div>
                <div class="card-price text-[#a3c98c] text-sm mt-1 font-medium">
                  From <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.price) %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <section id="services" class="max-w-7xl mx-auto py-20 border-t border-base-300 px-4">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16 reveal items-center">
          <div class="order-2 lg:order-1 px-4 lg:px-12">
            <p class="text-sm font-bold text-[#7a9d66] mb-4 uppercase tracking-widest">01 — Dịch vụ</p>
            <h2 class="text-4xl lg:text-5xl font-bold leading-tight mb-6">Thiết kế Hoa<br>Nghệ thuật</h2>
            <p class="text-base text-gray-600 mb-8 leading-relaxed">Chúng tôi tin rằng mỗi khoảnh khắc đều là duy nhất. Các thiết kế hoa của chúng tôi mang đậm tính kiến trúc, biến không gian thành một cảnh quan sống động.</p>
            <a href="#" class="btn bg-[#7a9d66] text-white hover:bg-[#607e4f] rounded-full px-8">Khám phá</a>
          </div>
          <div class="order-1 lg:order-2 rounded-4xl overflow-hidden shadow-lg h-[400px]">
            <img src="/images/bloomingwithpride.webp" class="w-full h-full object-cover" alt="Thiết kế Hoa Nghệ thuật">
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16 reveal items-center">
          <div class="rounded-4xl overflow-hidden shadow-lg h-[400px]">
            <img src="/images/summer_sale/bougainvillea.png" class="w-full h-full object-cover" alt="Sắp đặt Cây bản địa">
          </div>
          <div class="px-4 lg:px-12">
            <p class="text-sm font-bold text-[#7a9d66] mb-4 uppercase tracking-widest">02 — Dịch vụ</p>
            <h2 class="text-4xl lg:text-5xl font-bold leading-tight mb-6">Sắp đặt<br>Cây bản địa</h2>
            <p class="text-base text-gray-600 mb-8 leading-relaxed">Bộ sưu tập thực vật bản địa mang sắc màu của thiên nhiên vào trong ngôi nhà bạn một cách tinh tế và nhẹ nhàng.</p>
            <a href="#" class="btn bg-[#7a9d66] text-white hover:bg-[#607e4f] rounded-full px-8">Khám phá</a>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 reveal items-center">
          <div class="order-2 lg:order-1 px-4 lg:px-12">
            <p class="text-sm font-bold text-[#7a9d66] mb-4 uppercase tracking-widest">03 — Dịch vụ</p>
            <h2 class="text-4xl lg:text-5xl font-bold leading-tight mb-6">Ý tưởng Hoa<br>Thiết kế riêng</h2>
            <p class="text-base text-gray-600 mb-8 leading-relaxed">Hãy chia sẻ tầm nhìn của bạn, chúng tôi sẽ hiện thực hóa nó. Những tác phẩm tùy chỉnh mang đậm dấu ấn cá nhân và hình dáng độc bản.</p>
            <a href="#" class="btn bg-[#7a9d66] text-white hover:bg-[#607e4f] rounded-full px-8">Khám phá</a>
          </div>
          <div class="order-1 lg:order-2 rounded-4xl overflow-hidden shadow-lg h-[400px]">
            <img src="/images/gift/aster_3.jpg" class="w-full h-full object-cover" alt="Ý tưởng Hoa Thiết kế riêng">
          </div>
        </div>

      </section>

    </main> 

    <footer class="mt-10">
      <div class="relative w-full max-w-7xl mx-auto rounded-t-4xl overflow-hidden">
        <img src="/images/greeting.png" class="block w-full h-[600px] object-cover" alt="Background image"/>
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent pointer-events-none"></div>
        <div class="absolute inset-0 flex justify-between items-end p-8 md:p-12 text-white">
          <p class="text-2xl font-medium relative z-10">Hai Phong, Vietnam</p>
          <p class="absolute left-1/2 bottom-1/4 -translate-x-1/2 font-bold text-8xl md:text-9xl z-10">FP.</p>
          <a href="/contact" class="text-2xl font-medium relative z-10 hover:text-[#7a9d66] transition-colors">Contact</a>
        </div>
      </div>
    </footer>

    <script>
      // Chuyển hướng xem chi tiết sản phẩm 
      document.querySelectorAll('.gallery-card').forEach(card => {
        card.addEventListener('click', () => {
          window.location.href = '/product?id=' + card.dataset.id;
        });
      });

      /* ── Intersection Observer for reveal animations ── */
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });
      reveals.forEach(el => observer.observe(el));

      /* ── Xử lý Bộ lọc và Tìm kiếm ── */
      const searchInput = document.getElementById('searchInput');
      const categoryFilter = document.getElementById('categoryFilter');
      const priceFilter = document.getElementById('priceFilter');
      const sortFilter = document.getElementById('sortFilter');

      function filterProducts() {
        const keyword = searchInput.value.toLowerCase();
        const category = categoryFilter.value;
        const price = priceFilter.value;

        let cards = [...document.querySelectorAll('.gallery-card')];

        cards.forEach(card => {
            const name = card.querySelector('.card-name').innerText.toLowerCase();
            const cardCategory = card.dataset.category;
            const cardPrice = parseInt(card.dataset.price);

            let visible = true;
            if(keyword && !name.includes(keyword)) visible = false;
            if(category !== 'all' && cardCategory !== category) visible = false;
            
            if(price !== 'all') {
                const [min,max] = price.split('-');
                if(cardPrice < Number(min) || cardPrice > Number(max)) visible = false;
            }

            card.style.display = visible ? 'block' : 'none';
        });
        updateCounter();
      }

      function updateCounter(){
        const visibleProducts = [...document.querySelectorAll('.gallery-card')]
                .filter(card => getComputedStyle(card).display !== 'none').length;
        document.getElementById('productCount').innerText = visibleProducts;
      }

      function sortProducts(){
        const grid = document.querySelector('.gallery-grid');
        let cards = [...document.querySelectorAll('.gallery-card')];

        cards.sort((a,b)=>{
            const priceA = Number(a.dataset.price);
            const priceB = Number(b.dataset.price);
            const nameA = a.querySelector('.card-name').innerText;
            const nameB = b.querySelector('.card-name').innerText;

            switch(sortFilter.value){
                case 'price-asc': return priceA-priceB;
                case 'price-desc': return priceB-priceA;
                case 'name-asc': return nameA.localeCompare(nameB);
                case 'name-desc': return nameB.localeCompare(nameA);
                default: return 0;
            }
        });
        cards.forEach(card=>{ grid.appendChild(card); });
      }

      searchInput.addEventListener('input', filterProducts);
      categoryFilter.addEventListener('change', filterProducts);
      priceFilter.addEventListener('change', filterProducts);
      sortFilter.addEventListener('change', () => {
          sortProducts();
          filterProducts();
      });
      updateCounter();
    </script>

  </body>
</html>